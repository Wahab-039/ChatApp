APP_ENV=development
PORT=8080
DB_HOST=localhost
DB_PORT=5432
DB_USER=chatapp
DB_PASSWORD=change-me
DB_NAME=chatapp
DB_SSLMODE=disable
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_TTL=24h
LOGIN_RATE_LIMIT=10
LOGIN_RATE_WINDOW=1m

# EMQX (MQTT over WebSocket for clients; TCP for Go publisher)
EMQX_DASHBOARD_USERNAME=admin
EMQX_DASHBOARD_PASSWORD=change-me-dashboard-password
EMQX_API_URL=http://localhost:18083
EMQX_WS_URL=ws://localhost:8083/mqtt
EMQX_MQTT_TCP_URL=tcp://localhost:1883
EMQX_SERVICE_USERNAME=chatapp_service
EMQX_SERVICE_PASSWORD=replace-with-a-long-random-service-password
EMQX_CLIENT_ID=chatapp-api-1
EMQX_CONNECT_TIMEOUT=10s
